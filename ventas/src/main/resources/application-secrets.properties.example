# Copiar este archivo como application-secrets.properties (gitignored) y completar.
# Usar SIEMPRE el connection string pooled de Neon (host con sufijo -pooler).
spring.datasource.url=jdbc:postgresql://<host-pooler>.neon.tech/ventasdb?sslmode=require&channel_binding=require
spring.datasource.username=neondb_owner
spring.datasource.password=<password>
spring.datasource.driver-class-name=org.postgresql.Driver
