# Copiar como .env (gitignored) y completar con los datos del proyecto Neon.
# NEON_HOST: host POOLED (con sufijo -pooler), sin protocolo ni base de datos.
NEON_HOST=ep-xxxxx-pooler.region.neon.tech
NEON_USER=neondb_owner
NEON_PASSWORD=cambiar-por-la-password
# Secreto JWT compartido entre servicios (HS256, minimo 32 caracteres)
JWT_SECRET=paris-marketplace-dsy1103-secreto-desarrollo-2026!
